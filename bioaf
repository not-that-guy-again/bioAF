    echo "  ./bioaf seed seed_poc_data.py  # Seed demo data"
    echo "  ./bioaf shell backend       # Open shell in backend"
    echo "  ./bioaf dbshell             # Open psql session"
    echo "  ./bioaf backup              # Create database backup"
    echo "  ./bioaf update              # Update to the latest version"
    echo "  ./bioaf update 0.7.0        # Update to a specific version"
    echo ""
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------
command="${1:-help}"
shift || true

case "$command" in
    setup)        cmd_setup ;;
    create-admin) cmd_create_admin ;;
    start)        cmd_start ;;
    stop)     cmd_stop ;;
    restart)  cmd_restart ;;
    status)   cmd_status ;;
    logs)     cmd_logs "$@" ;;
    build)    cmd_build "$@" ;;
    migrate)  cmd_migrate ;;
    migrate-down) cmd_migrate_down "$@" ;;
    seed)     cmd_seed "$@" ;;
    backup)   cmd_backup ;;
    shell)    cmd_shell "$@" ;;
    dbshell)  cmd_dbshell ;;
    update)   cmd_update "$@" ;;
    reset-db) cmd_reset_db ;;
    register-outputs) cmd_register_outputs "$@" ;;
    help|-h|--help) cmd_help ;;
    *)
        red "Unknown command: $command"
        echo ""
        cmd_help
        exit 1
        ;;
esac
