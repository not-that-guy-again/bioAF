#!/usr/bin/env bash
# bioAF Management Script
# Usage: ./bioaf <command> [args]

set -euo pipefail

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
COMPOSE_FILE="$SCRIPT_DIR/docker/docker-compose.yml"
ENV_FILE="$SCRIPT_DIR/docker/.env"

DC="docker compose -f $COMPOSE_FILE --env-file $ENV_FILE"

# --progress is a global docker compose flag; must precede the build subcommand.
# Use the fancy TTY display when stdout is a real terminal, plain text otherwise.
[ -t 1 ] && _progress="auto" || _progress="plain"
DC_BUILD="docker compose --progress=$_progress -f $COMPOSE_FILE --env-file $ENV_FILE build"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
red()    { printf '\033[0;31m%s\033[0m\n' "$*"; }
green()  { printf '\033[0;32m%s\033[0m\n' "$*"; }
yellow() { printf '\033[0;33m%s\033[0m\n' "$*"; }
bold()   { printf '\033[1m%s\033[0m\n' "$*"; }

wait_for_db() {
    echo "Waiting for database to be ready..."
    local retries=30
    while [ $retries -gt 0 ]; do
        if $DC exec -T db pg_isready -U bioaf -q 2>/dev/null; then
            green "Database is ready."
            return 0
        fi
        retries=$((retries - 1))
        sleep 2
    done
    red "ERROR: Database did not become ready in time."
    exit 1
}

slugify() {
    echo "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//'
}

get_access_url() {
    # Try to detect the best URL for accessing the web UI.
    # Prefer the machine's public/private IP; fall back to localhost.
    local host
    host=$(hostname -I 2>/dev/null | awk '{print $1}') || true
    if [ -z "$host" ]; then
        host=$(ipconfig getifaddr en0 2>/dev/null) || true
    fi
    host=${host:-localhost}
    echo "https://${host}"
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------
cmd_setup() {
    bold "=== bioAF First-Run Setup ==="
    echo ""

    # Generate .env and TLS certs via install.sh (idempotent)
    "$SCRIPT_DIR/install.sh" generate-env --non-interactive
    "$SCRIPT_DIR/install.sh" generate-certs
    echo ""

    # Remove stale database volume if it exists. The volume holds the
    # old password from a previous install, which won't match the newly
    # generated credentials.
    local vol_name
    vol_name=$($DC config --format json 2>/dev/null | python3 -c "
import sys, json
cfg = json.load(sys.stdin)
for v in cfg.get('volumes', {}).values():
    print(v.get('name', ''))
    break
" 2>/dev/null || echo "")

    if [ -n "$vol_name" ] && docker volume inspect "$vol_name" > /dev/null 2>&1; then
        yellow "Removing existing database volume ($vol_name) to avoid password mismatch..."
        $DC down -v 2>/dev/null || true
    fi

    # Build and start
    bold "Building and starting containers..."
    $DC_BUILD
    $DC up -d

    # Wait for DB
    wait_for_db

    # Run migrations
    bold "Running database migrations..."
    $DC exec -T backend alembic -c alembic/alembic.ini upgrade head
    green "Migrations complete."
    echo ""

    # Generate setup code via the Python service
    bold "Generating setup code..."
    local setup_response
    setup_response=$($DC exec -T backend python -c "
import asyncio, json
from app.services.setup_code_service import generate_setup_code_for_cli
result = asyncio.run(generate_setup_code_for_cli())
print(json.dumps(result))
")

    local already_setup
    already_setup=$(echo "$setup_response" | python3 -c "import sys, json; print(json.load(sys.stdin).get('already_setup', False))")

    if [ "$already_setup" = "True" ]; then
        local access_url
        access_url=$(get_access_url)
        echo ""
        green "bioAF is already set up."
        echo "Log in at: $access_url"
        return 0
    fi

    local setup_code
    setup_code=$(echo "$setup_response" | python3 -c "import sys, json; print(json.load(sys.stdin).get('code', ''))")

    local access_url
    access_url=$(get_access_url)

    echo ""
    bold "=================================================="
    bold "  bioAF Setup Code"
    bold "=================================================="
    echo ""
    echo "  Your one-time setup code is:"
    echo ""
    bold "    $setup_code"
    echo ""
    echo "  Open the setup wizard in your browser:"
    echo ""
    echo "    ${access_url}/setup"
    echo ""
    echo "  Enter the code above to begin platform setup."
    echo "  The code expires in 1 hour."
    echo ""
    bold "=================================================="
    echo ""
    echo "Management commands:"
    echo "  ./bioaf status     Show service status"
    echo "  ./bioaf logs       Tail logs (use -n N for more lines)"
    echo "  ./bioaf stop       Stop all services"
    echo "  ./bioaf help       Show all commands"
}

cmd_start() {
    bold "=== Starting Services ==="

    for svc in db backend frontend nginx; do
        echo "Starting $svc..."
        $DC up -d "$svc"

        if [ "$svc" = "db" ]; then
            wait_for_db
        fi

        # Give backend time to bind before starting frontend
        if [ "$svc" = "backend" ]; then
            echo "Waiting for backend to initialize..."
            sleep 3
        fi
    done

    echo ""
    green "All services started."
    cmd_status
}

cmd_stop() {
    bold "=== Stopping Services ==="

    for svc in nginx frontend backend db; do
        echo "Stopping $svc..."
        $DC stop "$svc"
    done

    echo ""
    green "All services stopped."
}

cmd_restart() {
    cmd_stop
    echo ""
    cmd_start
}

cmd_status() {
    bold "=== Service Status ==="
    echo ""

    for svc in db backend frontend nginx; do
        local state
        state=$($DC ps --format "{{.State}}" "$svc" 2>/dev/null || echo "not created")
        case "$state" in
            running) green "  $svc: running" ;;
            exited)  red   "  $svc: exited" ;;
            *)       yellow "  $svc: $state" ;;
        esac
    done

    echo ""
}

cmd_logs() {
    local tail_lines=100
    local service=""
    while [ $# -gt 0 ]; do
        case "$1" in
            -n)
                tail_lines="${2:-100}"
                shift 2
                ;;
            *)
                service="$1"
                shift
                ;;
        esac
    done
    if [ -n "$service" ]; then
        $DC logs -f --tail="$tail_lines" "$service"
    else
        $DC logs -f --tail="$tail_lines"
    fi
}

cmd_migrate() {
    bold "=== Running Database Migrations ==="
    wait_for_db
    $DC exec -T backend alembic -c alembic/alembic.ini upgrade head
    green "Migrations complete."
}

cmd_migrate_down() {
    local target="${1:-}"
    if [ -z "$target" ]; then
        red "Usage: ./bioaf migrate-down <revision>"
        echo "  Downgrades the database to the specified alembic revision."
        echo "  Example: ./bioaf migrate-down 052"
        return 1
    fi
    bold "=== Downgrading Database to Revision $target ==="
    wait_for_db
    $DC exec -T backend alembic -c alembic/alembic.ini downgrade "$target"
    green "Downgrade to $target complete."
}

cmd_backup() {
    bold "=== Database Backup ==="
    local timestamp
    timestamp=$(date +%Y%m%d_%H%M%S)
    local backup_file="$SCRIPT_DIR/backups/bioaf_${timestamp}.sql.gz"
    mkdir -p "$SCRIPT_DIR/backups"

    $DC exec -T db pg_dump -U bioaf bioaf | gzip > "$backup_file"
    green "Backup saved to: $backup_file"
}

cmd_update() {
    bold "=== Updating bioAF ==="

    echo "Pulling latest code..."
    git -C "$SCRIPT_DIR" pull

    echo "Rebuilding containers..."
    $DC_BUILD
    $DC up -d

    wait_for_db

    echo "Running migrations..."
    $DC exec -T backend alembic -c alembic/alembic.ini upgrade head

    green "Update complete."
}

cmd_build() {
    local service="${1:-}"
    if [ -n "$service" ]; then
        bold "=== Building $service ==="
        $DC_BUILD "$service"
        green "$service built."
    else
        bold "=== Building All Services ==="
        $DC_BUILD
        green "All services built."
    fi
}

cmd_shell() {
    local service="${1:-backend}"
    bold "Opening shell in $service..."
    $DC exec "$service" sh
}

cmd_dbshell() {
    bold "Opening database shell..."
    $DC exec db psql -U bioaf bioaf
}

cmd_seed() {
    local script="${1:-}"
    if [ -z "$script" ]; then
        red "Usage: ./bioaf seed <script.py>"
        echo ""
        echo "Available seed scripts:"
        # List .py files in scripts/ that contain 'seed' or 'generate' in the name
        find "$SCRIPT_DIR/scripts" -maxdepth 1 -name "*.py" -type f 2>/dev/null | sort | while read -r f; do
            echo "  $(basename "$f")"
        done
        exit 1
    fi

    # Resolve the script path relative to scripts/ if not absolute
    local script_path
    if [ -f "$SCRIPT_DIR/scripts/$script" ]; then
        script_path="scripts/$script"
    elif [ -f "$script" ]; then
        script_path="$script"
    else
        red "Script not found: $script"
        red "Looked in: $SCRIPT_DIR/scripts/$script"
        exit 1
    fi

    bold "=== Running seed script: $script_path ==="
    $DC exec -T backend python "$script_path"
    green "Seed script complete."
}

cmd_create_admin() {
    yellow "DEPRECATED: 'create-admin' has been replaced by the setup wizard."
    echo "Run './bioaf setup' instead -- it generates a setup code that you"
    echo "enter in the web UI to create your admin account securely."
}

cmd_reset_db() {
    bold "=== Database Reset ==="
    red "WARNING: This will destroy ALL data in the database."
    read -rp "Type 'yes' to confirm: " confirm
    if [ "$confirm" != "yes" ]; then
        echo "Aborted."
        exit 0
    fi

    echo "Stopping backend and frontend..."
    $DC stop backend frontend nginx 2>/dev/null || true

    # Ensure the db container is running so we can drop the database
    local db_state
    db_state=$($DC ps --format "{{.State}}" db 2>/dev/null || echo "not created")
    if [ "$db_state" != "running" ]; then
        echo "Starting database..."
        $DC up -d db
    fi
    wait_for_db

    # Terminate any lingering connections before dropping
    echo "Dropping and recreating database..."
    $DC exec -T db psql -U bioaf -d postgres -c \
        "SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname = 'bioaf' AND pid <> pg_backend_pid();" \
        > /dev/null 2>&1 || true
    $DC exec -T db dropdb -U bioaf --if-exists bioaf
    $DC exec -T db createdb -U bioaf bioaf

    echo "Starting backend..."
    $DC up -d backend
    wait_for_db

    echo "Running migrations..."
    $DC exec -T backend alembic -c alembic/alembic.ini upgrade head

    green "Database reset complete. Run './bioaf setup' to generate a new setup code."
}

cmd_register_outputs() {
    bold "=== Register Pipeline Output Files ==="
    $DC exec -T backend python -m app.cli.register_outputs "$@"
}

cmd_help() {
    bold "bioAF Management"
    echo ""
    echo "Usage: ./bioaf <command> [args]"
    echo ""
    bold "First-Run:"
    echo "  setup               Start services and generate a setup code for the web wizard"
    echo ""
    bold "Service Management:"
    echo "  start               Start all services"
    echo "  stop                Stop all services"
    echo "  restart             Restart all services"
    echo "  status              Show status of all services"
    echo "  logs [service] [-n N]  Tail logs (default 100 lines, use -n to change)"
    echo "  build [service]     Build (or rebuild) container images"
    echo ""
    bold "Database:"
    echo "  migrate             Run alembic database migrations"
    echo "  migrate-down <rev>  Downgrade database to a specific revision"
    echo "  seed <script.py>    Run a seed/data script in the backend container"
    echo "  backup              Create a database backup"
    echo "  reset-db            Destroy and recreate the database (with confirmation)"
    echo ""
    bold "Debugging:"
    echo "  shell [service]     Open a shell in a container (default: backend)"
    echo "  dbshell             Open a psql session to the database"
    echo ""
    bold "Pipeline:"
    echo "  register-outputs [--run-id N] [--force]"
    echo "                      Register pipeline output files from GCS into the database"
    echo ""
    bold "Maintenance:"
    echo "  update              Pull latest code, rebuild containers, and run migrations"
    echo "  help                Show this help message"
    echo ""
    bold "Examples:"
    echo "  ./bioaf setup               # First-time setup"
    echo "  ./bioaf build               # Build all container images"
    echo "  ./bioaf start               # Start services"
    echo "  ./bioaf logs backend        # Tail backend logs (last 100 lines)"
    echo "  ./bioaf logs backend -n 500 # Tail backend logs (last 500 lines)"
    echo "  ./bioaf migrate             # Run pending migrations"
    echo "  ./bioaf seed seed_poc_data.py  # Seed demo data"
    echo "  ./bioaf shell backend       # Open shell in backend"
    echo "  ./bioaf dbshell             # Open psql session"
    echo "  ./bioaf backup              # Create database backup"
    echo ""
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------
command="${1:-help}"
shift || true

case "$command" in
    setup)        cmd_setup ;;
    create-admin) cmd_create_admin ;;
    start)        cmd_start ;;
    stop)     cmd_stop ;;
    restart)  cmd_restart ;;
    status)   cmd_status ;;
    logs)     cmd_logs "$@" ;;
    build)    cmd_build "$@" ;;
    migrate)  cmd_migrate ;;
    migrate-down) cmd_migrate_down "$@" ;;
    seed)     cmd_seed "$@" ;;
    backup)   cmd_backup ;;
    shell)    cmd_shell "$@" ;;
    dbshell)  cmd_dbshell ;;
    update)   cmd_update ;;
    reset-db) cmd_reset_db ;;
    register-outputs) cmd_register_outputs "$@" ;;
    help|-h|--help) cmd_help ;;
    *)
        red "Unknown command: $command"
        echo ""
        cmd_help
        exit 1
        ;;
esac
