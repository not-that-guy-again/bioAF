#!/usr/bin/env bash
# bioAF Management Script
# Usage: ./bioaf <command> [args]

set -euo pipefail

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
COMPOSE_FILE="$SCRIPT_DIR/docker/docker-compose.yml"
ENV_FILE="$SCRIPT_DIR/docker/.env"

DC="docker compose -f $COMPOSE_FILE --env-file $ENV_FILE"

# --progress is a global docker compose flag; must precede the build subcommand.
# Use the fancy TTY display when stdout is a real terminal, plain text otherwise.
[ -t 1 ] && _progress="auto" || _progress="plain"
DC_BUILD="docker compose --progress=$_progress -f $COMPOSE_FILE --env-file $ENV_FILE build"
DC_PULL="docker compose -f $COMPOSE_FILE --env-file $ENV_FILE pull"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
red()    { printf '\033[0;31m%s\033[0m\n' "$*"; }
green()  { printf '\033[0;32m%s\033[0m\n' "$*"; }
yellow() { printf '\033[0;33m%s\033[0m\n' "$*"; }
bold()   { printf '\033[1m%s\033[0m\n' "$*"; }

wait_for_db() {
    echo "Waiting for database to be ready..."
    local retries=30
    while [ $retries -gt 0 ]; do
        if $DC exec -T db pg_isready -U bioaf -q 2>/dev/null; then
            green "Database is ready."
            return 0
        fi
        retries=$((retries - 1))
        sleep 2
    done
    red "ERROR: Database did not become ready in time."
    exit 1
}

slugify() {
    echo "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//'
}

get_access_url() {
    # Try to detect the best URL for accessing the web UI.
    # On GCE, the external IP is NAT'd and not visible to the OS,
    # so we query the metadata server for it.
    local host=""

    if is_gce; then
        host=$(curl -sf -m 2 -H "Metadata-Flavor: Google" \
            "http://169.254.169.254/computeMetadata/v1/instance/network-interfaces/0/access-configs/0/external-ip" \
            2>/dev/null) || true
    fi

    if [ -z "$host" ]; then
        host=$(hostname -I 2>/dev/null | awk '{print $1}') || true
    fi
    if [ -z "$host" ]; then
        host=$(ipconfig getifaddr en0 2>/dev/null) || true
    fi
    host=${host:-localhost}
    echo "https://${host}"
}

is_gce() {
    curl -sf -m 1 -H "Metadata-Flavor: Google" \
        "http://169.254.169.254/computeMetadata/v1/project/project-id" \
        >/dev/null 2>&1
}

ensure_cloud_logging() {
    # Install and configure the Google Cloud Ops Agent on GCE so that
    # all Docker container logs are forwarded to Cloud Logging.
    # Idempotent -- safe to call on every start.

    if ! is_gce; then
        return 0
    fi

    # Install the Ops Agent if the binary is not present
    if ! command -v google_cloud_ops_agent_engine &>/dev/null; then
        bold "Installing Google Cloud Ops Agent..."
        curl -sSO https://dl.google.com/cloudagents/add-google-cloud-ops-agent-repo.sh
        sudo bash add-google-cloud-ops-agent-repo.sh --also-install
        rm -f add-google-cloud-ops-agent-repo.sh
    fi

    # Deploy the Docker log collection config if not already present
    local ops_config="/etc/google-cloud-ops-agent/config.yaml"
    if [ ! -f "$ops_config" ] || ! grep -q "docker_logs" "$ops_config" 2>/dev/null; then
        bold "Configuring Ops Agent for Docker log collection..."
        sudo mkdir -p /etc/google-cloud-ops-agent
        sudo cp "$SCRIPT_DIR/docker/ops-agent-config.yaml" "$ops_config"
        sudo systemctl restart google-cloud-ops-agent
        green "Cloud Logging configured -- logs will appear in Google Cloud Console."
    fi
}

ensure_update_agent() {
    # Install the update agent systemd service so the backend can trigger
    # host-level updates via a trigger file. Idempotent.

    # Skip on non-systemd systems and non-Linux
    if ! command -v systemctl &>/dev/null; then
        return 0
    fi

    # Create directories
    mkdir -p "$SCRIPT_DIR/update-requests" "$SCRIPT_DIR/update-status"

    local service_name="bioaf-update-agent"
    local service_file="/etc/systemd/system/${service_name}.service"
    local current_user
    current_user=$(whoami)
    local current_group
    current_group=$(id -gn)

    # Check if already installed with correct paths
    if [ -f "$service_file" ] && grep -q "$SCRIPT_DIR" "$service_file" 2>/dev/null; then
        # Ensure it's running
        if ! systemctl is-active --quiet "$service_name" 2>/dev/null; then
            sudo systemctl start "$service_name"
        fi
        return 0
    fi

    bold "Installing update agent service..."
    sed -e "s|__BIOAF_DIR__|$SCRIPT_DIR|g" \
        -e "s|__BIOAF_USER__|$current_user|g" \
        -e "s|__BIOAF_GROUP__|$current_group|g" \
        "$SCRIPT_DIR/docker/bioaf-update-agent.service" | sudo tee "$service_file" > /dev/null

    sudo systemctl daemon-reload
    sudo systemctl enable "$service_name"
    sudo systemctl start "$service_name"
    green "Update agent installed and running."
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------
cmd_setup() {
    # OS gate -- catch macOS/Windows before anything else
    local os
    os="$(uname -s)"
    case "$os" in
        Darwin)
            echo ""
            red "bioAF cannot be installed on macOS."
            echo ""
            echo "bioAF requires a Linux server, typically a VM in Google Cloud."
            echo "See the installation guide for step-by-step instructions:"
            echo ""
            bold "  https://bioaf.co/docs/installation/gcp-setup/"
            echo ""
            exit 1
            ;;
        MINGW*|MSYS*|CYGWIN*|Windows_NT)
            echo ""
            red "bioAF cannot be installed on Windows."
            echo ""
            echo "bioAF requires a Linux server, typically a VM in Google Cloud."
            echo "See the installation guide for step-by-step instructions:"
            echo ""
            bold "  https://bioaf.co/docs/installation/gcp-setup/"
            echo ""
            exit 1
            ;;
    esac

    # If Docker is installed but the socket is inaccessible, the user was likely
    # added to the docker group by the VM startup script but hasn't re-logged in.
    # Re-exec this script under `sg docker` to activate the group inline.
    if command -v docker &>/dev/null && ! docker info &>/dev/null; then
        if id -nG 2>/dev/null | grep -qw docker || grep -q "docker.*$(whoami)\|$(whoami).*docker" /etc/group 2>/dev/null; then
            yellow "Activating docker group for this session..."
            exec sg docker -c "'$0' setup"
        fi
    fi

    bold "=== bioAF First-Run Setup ==="
    echo ""

    # Auto-run install.sh if it hasn't been run yet
    if [ ! -f "$ENV_FILE" ] || [ ! -f "$SCRIPT_DIR/docker/certs/tls.crt" ]; then
        bold "Running installer (first time)..."
        "$SCRIPT_DIR/install.sh" --non-interactive --quiet
        echo ""
    else
        # .env and certs exist -- just ensure they're current (idempotent)
        "$SCRIPT_DIR/install.sh" generate-env --non-interactive
        "$SCRIPT_DIR/install.sh" generate-certs
        echo ""
    fi

    # Remove stale database volume if it exists. The volume holds the
    # old password from a previous install, which won't match the newly
    # generated credentials.
    local vol_name
    vol_name=$($DC config --format json 2>/dev/null | python3 -c "
import sys, json
cfg = json.load(sys.stdin)
for v in cfg.get('volumes', {}).values():
    print(v.get('name', ''))
    break
" 2>/dev/null || echo "")

    if [ -n "$vol_name" ] && docker volume inspect "$vol_name" > /dev/null 2>&1; then
        yellow "Removing existing database volume ($vol_name) to avoid password mismatch..."
        $DC down -v 2>/dev/null || true
    fi

    # Cloud Logging (GCE only, idempotent)
    ensure_cloud_logging

    # Update agent (idempotent)
    ensure_update_agent

    # Pull pre-built images and start
    bold "Pulling pre-built images..."
    set_image_tag
    $DC_PULL backend frontend
    $DC up -d

    # Wait for DB
    wait_for_db

    # Run migrations
    bold "Running database migrations..."
    $DC exec -T backend alembic -c alembic/alembic.ini upgrade head
    green "Migrations complete."
    echo ""

    # Generate setup code via the Python service
    bold "Generating setup code..."
    local setup_response
    setup_response=$($DC exec -T backend python -c "
import asyncio, json
from app.services.setup_code_service import generate_setup_code_for_cli
result = asyncio.run(generate_setup_code_for_cli())
print(json.dumps(result))
")

    local already_setup
    already_setup=$(echo "$setup_response" | python3 -c "import sys, json; print(json.load(sys.stdin).get('already_setup', False))")

    if [ "$already_setup" = "True" ]; then
        local access_url
        access_url=$(get_access_url)
        echo ""
        green "bioAF is already set up."
        echo "Log in at: $access_url"
        return 0
    fi

    local setup_code
    setup_code=$(echo "$setup_response" | python3 -c "import sys, json; print(json.load(sys.stdin).get('code', ''))")

    local access_url
    access_url=$(get_access_url)

    echo ""
    bold "=================================================="
    bold "  bioAF Setup Code"
    bold "=================================================="
    echo ""
    echo "  Your one-time setup code is:"
    echo ""
    green "    $setup_code"
    echo ""
    echo "  Open the setup wizard in your browser:"
    echo ""
    echo "    ${access_url}/setup"
    echo ""
    echo "  Enter the code above to begin platform setup."
    echo "  The code expires in 1 hour."
    echo ""
    bold "=================================================="
    echo ""
    echo "Management commands:"
    echo "  ./bioaf status     Show service status"
    echo "  ./bioaf logs       Tail logs (use -n N for more lines)"
    echo "  ./bioaf stop       Stop all services"
    echo "  ./bioaf help       Show all commands"
}

cmd_start() {
    bold "=== Starting Services ==="
    set_image_tag

    for svc in db backend frontend nginx; do
        echo "Starting $svc..."
        $DC up -d "$svc"

        if [ "$svc" = "db" ]; then
            wait_for_db
        fi

        # Give backend time to bind before starting frontend
        if [ "$svc" = "backend" ]; then
            echo "Waiting for backend to initialize..."
            sleep 3
        fi
    done

    echo ""
    green "All services started."
    cmd_status
}

cmd_stop() {
    bold "=== Stopping Services ==="

    for svc in nginx frontend backend db; do
        echo "Stopping $svc..."
        $DC stop "$svc"
    done

    echo ""
    green "All services stopped."
}

cmd_restart() {
    cmd_stop
    echo ""
    cmd_start
}

cmd_status() {
    bold "=== Service Status ==="
    echo ""

    for svc in db backend frontend nginx; do
        local state
        state=$($DC ps --format "{{.State}}" "$svc" 2>/dev/null || echo "not created")
        case "$state" in
            running) green "  $svc: running" ;;
            exited)  red   "  $svc: exited" ;;
            *)       yellow "  $svc: $state" ;;
        esac
    done

    echo ""
}

cmd_logs() {
    local tail_lines=100
    local service=""
    while [ $# -gt 0 ]; do
        case "$1" in
            -n)
                tail_lines="${2:-100}"
                shift 2
                ;;
            *)
                service="$1"
                shift
                ;;
        esac
    done
    if [ -n "$service" ]; then
        $DC logs -f --tail="$tail_lines" "$service"
    else
        $DC logs -f --tail="$tail_lines"
    fi
}

cmd_migrate() {
    bold "=== Running Database Migrations ==="
    wait_for_db
    $DC exec -T backend alembic -c alembic/alembic.ini upgrade head
    green "Migrations complete."
}

cmd_migrate_down() {
    local target="${1:-}"
    if [ -z "$target" ]; then
        red "Usage: ./bioaf migrate-down <revision>"
        echo "  Downgrades the database to the specified alembic revision."
        echo "  Example: ./bioaf migrate-down 052"
        return 1
    fi
    bold "=== Downgrading Database to Revision $target ==="
    wait_for_db
    $DC exec -T backend alembic -c alembic/alembic.ini downgrade "$target"
    green "Downgrade to $target complete."
}

cmd_backup() {
    bold "=== Database Backup ==="
    local timestamp
    timestamp=$(date +%Y%m%d_%H%M%S)
    local backup_file="$SCRIPT_DIR/backups/bioaf_${timestamp}.sql.gz"
    mkdir -p "$SCRIPT_DIR/backups"

    $DC exec -T db pg_dump -U bioaf bioaf | gzip > "$backup_file"
    green "Backup saved to: $backup_file"
}

get_current_version() {
    # Read version from backend/pyproject.toml (single source of truth)
    python3 -c "
import tomllib, pathlib
data = tomllib.loads(pathlib.Path('$SCRIPT_DIR/backend/pyproject.toml').read_text())
print(data['project']['version'])
" 2>/dev/null || echo "unknown"
}

set_image_tag() {
    # Export the image tag so docker-compose.yml resolves ghcr.io image references.
    export BIOAF_IMAGE_TAG="v$(get_current_version)"
}

get_latest_github_version() {
    # Query GitHub Releases API for the latest release tag
    local response
    response=$(curl -sf --max-time 10 \
        -H "Accept: application/vnd.github+json" \
        "https://api.github.com/repos/not-that-guy-again/bioAF/releases/latest" 2>/dev/null) || {
        red "ERROR: Could not reach GitHub to check for the latest version."
        echo "Provide a specific version instead: ./bioaf update <version>"
        exit 1
    }

    local tag
    tag=$(echo "$response" | python3 -c "import sys, json; print(json.load(sys.stdin).get('tag_name', ''))" 2>/dev/null)

    if [ -z "$tag" ]; then
        red "ERROR: Could not determine the latest version from GitHub."
        exit 1
    fi

    # Strip leading 'v' if present
    echo "${tag#v}"
}

cmd_update() {
    local target_version="${1:-}"
    local current_version
    current_version=$(get_current_version)

    # If no version specified, fetch the latest from GitHub
    if [ -z "$target_version" ]; then
        echo "Checking GitHub for the latest release..."
        target_version=$(get_latest_github_version)
    fi

    # Strip leading 'v' if the user passed one
    target_version="${target_version#v}"

    # Validate version format (semver: X.Y.Z)
    if ! echo "$target_version" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$'; then
        red "ERROR: Invalid version format '$target_version'. Expected format: X.Y.Z"
        exit 1
    fi

    # Check if already on the target version
    if [ "$current_version" = "$target_version" ]; then
        green "Already running version $current_version. Nothing to update."
        exit 0
    fi

    bold "=== bioAF Update ==="
    echo ""
    echo "  Current version:  $current_version"
    echo "  Target version:   $target_version"
    echo ""

    # Confirmation prompt (skipped when called with --yes flag for automation)
    local auto_confirm=false
    if [ "${2:-}" = "--yes" ] || [ "${BIOAF_AUTO_CONFIRM:-}" = "1" ]; then
        auto_confirm=true
    fi

    if [ "$auto_confirm" = false ]; then
        read -rp "Proceed with update? [y/N] " confirm
        if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
            echo "Update cancelled."
            exit 0
        fi
    fi

    # Write status file for the backend to track progress
    local status_dir="$SCRIPT_DIR/update-status"
    mkdir -p "$status_dir"
    cat > "$status_dir/current.json" <<STATUSEOF
{"status": "in_progress", "from_version": "$current_version", "to_version": "$target_version", "step": "backup", "started_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"}
STATUSEOF

    # Back up the database before updating
    echo ""
    bold "Backing up database..."
    local timestamp
    timestamp=$(date +%Y%m%d_%H%M%S)
    local backup_file="$SCRIPT_DIR/backups/bioaf_pre_update_${current_version}_to_${target_version}_${timestamp}.sql.gz"
    mkdir -p "$SCRIPT_DIR/backups"
    if $DC exec -T db pg_dump -U bioaf bioaf 2>/dev/null | gzip > "$backup_file"; then
        green "Backup saved: $backup_file"
    else
        red "WARNING: Database backup failed. Continuing without backup."
        rm -f "$backup_file"
    fi

    # Fetch and checkout the target version
    cat > "$status_dir/current.json" <<STATUSEOF
{"status": "in_progress", "from_version": "$current_version", "to_version": "$target_version", "step": "checkout", "started_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"}
STATUSEOF

    echo ""
    bold "Fetching version $target_version..."
    git -C "$SCRIPT_DIR" fetch --tags --force
    if ! git -C "$SCRIPT_DIR" rev-parse "v${target_version}" >/dev/null 2>&1; then
        red "ERROR: Tag v${target_version} not found in the repository."
        cat > "$status_dir/current.json" <<STATUSEOF
{"status": "failed", "from_version": "$current_version", "to_version": "$target_version", "step": "checkout", "error": "Tag not found"}
STATUSEOF
        exit 1
    fi
    git -C "$SCRIPT_DIR" checkout "v${target_version}"

    # Pull pre-built images while old containers are still running,
    # so the only downtime is the restart + migrate window.
    cat > "$status_dir/current.json" <<STATUSEOF
{"status": "in_progress", "from_version": "$current_version", "to_version": "$target_version", "step": "pull", "started_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"}
STATUSEOF

    echo ""
    export BIOAF_IMAGE_TAG="v${target_version}"
    bold "Pulling pre-built images..."
    $DC_PULL backend frontend

    # Warning window before restart: give the UI time to show a countdown
    # so users know the app is about to go offline briefly. Skipped when
    # BIOAF_SKIP_RESTART_WARN=1 (useful for tests and dev overrides).
    local warn_seconds="${BIOAF_RESTART_WARN_SECONDS:-60}"
    if [ "${BIOAF_SKIP_RESTART_WARN:-0}" != "1" ] && [ "$warn_seconds" -gt 0 ]; then
        cat > "$status_dir/current.json" <<STATUSEOF
{"status": "in_progress", "from_version": "$current_version", "to_version": "$target_version", "step": "warn", "started_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"}
STATUSEOF
        echo ""
        yellow "Restarting in ${warn_seconds}s (notifying active users)..."
        sleep "$warn_seconds"
    fi

    # Restart services with new images
    cat > "$status_dir/current.json" <<STATUSEOF
{"status": "in_progress", "from_version": "$current_version", "to_version": "$target_version", "step": "restart", "started_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"}
STATUSEOF

    $DC up -d
    wait_for_db

    # Cloud Logging (GCE only, idempotent) -- run after restart so it
    # does not block the update while containers are down.
    ensure_cloud_logging

    # Run migrations
    cat > "$status_dir/current.json" <<STATUSEOF
{"status": "in_progress", "from_version": "$current_version", "to_version": "$target_version", "step": "migrate", "started_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"}
STATUSEOF

    echo ""
    bold "Running migrations..."
    $DC exec -T backend alembic -c alembic/alembic.ini upgrade head

    # Write success status
    local new_version
    new_version=$(get_current_version)
    cat > "$status_dir/current.json" <<STATUSEOF
{"status": "completed", "from_version": "$current_version", "to_version": "$new_version", "completed_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"}
STATUSEOF

    echo ""
    green "=================================================="
    green "  Update complete: $current_version -> $new_version"
    green "=================================================="
}

cmd_build() {
    set_image_tag
    local service="${1:-}"
    if [ -n "$service" ]; then
        bold "=== Building $service ==="
        $DC_BUILD "$service"
        green "$service built."
    else
        bold "=== Building All Services ==="
        $DC_BUILD
        green "All services built."
    fi
}

cmd_shell() {
    local service="${1:-backend}"
    bold "Opening shell in $service..."
    $DC exec "$service" sh
}

cmd_dbshell() {
    bold "Opening database shell..."
    $DC exec db psql -U bioaf bioaf
}

cmd_seed() {
    local script="${1:-}"
    if [ -z "$script" ]; then
        red "Usage: ./bioaf seed <script.py>"
        echo ""
        echo "Available seed scripts:"
        # List .py files in scripts/ that contain 'seed' or 'generate' in the name
        find "$SCRIPT_DIR/scripts" -maxdepth 1 -name "*.py" -type f 2>/dev/null | sort | while read -r f; do
            echo "  $(basename "$f")"
        done
        exit 1
    fi

    # Resolve the script path relative to scripts/ if not absolute
    local script_path
    if [ -f "$SCRIPT_DIR/scripts/$script" ]; then
        script_path="scripts/$script"
    elif [ -f "$script" ]; then
        script_path="$script"
    else
        red "Script not found: $script"
        red "Looked in: $SCRIPT_DIR/scripts/$script"
        exit 1
    fi

    bold "=== Running seed script: $script_path ==="
    $DC exec -T backend python "$script_path"
    green "Seed script complete."
}

cmd_create_admin() {
    yellow "DEPRECATED: 'create-admin' has been replaced by the setup wizard."
    echo "Run './bioaf setup' instead -- it generates a setup code that you"
    echo "enter in the web UI to create your admin account securely."
}

cmd_reset_db() {
    bold "=== Database Reset ==="
    red "WARNING: This will destroy ALL data in the database."
    read -rp "Type 'yes' to confirm: " confirm
    if [ "$confirm" != "yes" ]; then
        echo "Aborted."
        exit 0
    fi

    echo "Stopping backend and frontend..."
    $DC stop backend frontend nginx 2>/dev/null || true

    # Ensure the db container is running so we can drop the database
    local db_state
    db_state=$($DC ps --format "{{.State}}" db 2>/dev/null || echo "not created")
    if [ "$db_state" != "running" ]; then
        echo "Starting database..."
        $DC up -d db
    fi
    wait_for_db

    # Terminate any lingering connections before dropping
    echo "Dropping and recreating database..."
    $DC exec -T db psql -U bioaf -d postgres -c \
        "SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname = 'bioaf' AND pid <> pg_backend_pid();" \
        > /dev/null 2>&1 || true
    $DC exec -T db dropdb -U bioaf --if-exists bioaf
    $DC exec -T db createdb -U bioaf bioaf

    echo "Starting backend..."
    $DC up -d backend
    wait_for_db

    echo "Running migrations..."
    $DC exec -T backend alembic -c alembic/alembic.ini upgrade head

    green "Database reset complete. Run './bioaf setup' to generate a new setup code."
}

cmd_register_outputs() {
    bold "=== Register Pipeline Output Files ==="
    $DC exec -T backend python -m app.cli.register_outputs "$@"
}

