#!/usr/bin/env bash
# bioAF Management Script
# Usage: ./bioaf <command> [args]

set -euo pipefail

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
COMPOSE_FILE="$SCRIPT_DIR/docker/docker-compose.yml"
ENV_FILE="$SCRIPT_DIR/docker/.env"

DC="docker compose -f $COMPOSE_FILE --env-file $ENV_FILE"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
red()    { printf '\033[0;31m%s\033[0m\n' "$*"; }
green()  { printf '\033[0;32m%s\033[0m\n' "$*"; }
yellow() { printf '\033[0;33m%s\033[0m\n' "$*"; }
bold()   { printf '\033[1m%s\033[0m\n' "$*"; }

wait_for_db() {
    echo "Waiting for database to be ready..."
    local retries=30
    while [ $retries -gt 0 ]; do
        if $DC exec -T db pg_isready -U bioaf -q 2>/dev/null; then
            green "Database is ready."
            return 0
        fi
        retries=$((retries - 1))
        sleep 2
    done
    red "ERROR: Database did not become ready in time."
    exit 1
}

slugify() {
    echo "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//'
}

get_access_url() {
    # Try to detect the best URL for accessing the web UI.
    # Prefer the machine's public/private IP; fall back to localhost.
    local host
    host=$(hostname -I 2>/dev/null | awk '{print $1}') || true
    if [ -z "$host" ]; then
        host=$(ipconfig getifaddr en0 2>/dev/null) || true
    fi
    host=${host:-localhost}
    echo "http://${host}:8080"
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------
cmd_setup() {
    bold "=== bioAF First-Run Setup ==="
    echo ""

    # Prompt for org name
    read -rp "Organization name: " org_name
    if [ -z "$org_name" ]; then
        red "Organization name cannot be empty."
        exit 1
    fi

    org_slug=$(slugify "$org_name")
    echo "  Org slug: $org_slug"
    echo ""

    # Prompt for admin email
    read -rp "Admin email: " admin_email
    if [ -z "$admin_email" ]; then
        red "Admin email cannot be empty."
        exit 1
    fi

    # Prompt for admin password (hidden)
    while true; do
        read -rsp "Admin password: " admin_password
        echo ""
        read -rsp "Confirm password: " admin_password_confirm
        echo ""
        if [ "$admin_password" = "$admin_password_confirm" ]; then
            break
        fi
        red "Passwords do not match. Try again."
    done
    echo ""

    # Generate secrets
    pg_password=$(openssl rand -hex 16)
    secret_key=$(openssl rand -hex 32)

    # Write .env file
    cat > "$ENV_FILE" <<ENVEOF
# Generated by bioaf setup on $(date -u +"%Y-%m-%dT%H:%M:%SZ")
# PostgreSQL
POSTGRES_USER=bioaf
POSTGRES_PASSWORD=$pg_password
POSTGRES_DB=bioaf

# Backend
DATABASE_URL=postgresql+asyncpg://bioaf:${pg_password}@db:5432/bioaf
SECRET_KEY=$secret_key

# Environment
BIOAF_ENVIRONMENT=production
ENVEOF

    green "Environment file written to docker/.env"
    echo ""

    # Build and start
    bold "Building and starting containers..."
    $DC up -d --build

    # Wait for DB
    wait_for_db

    # Run migrations
    bold "Running database migrations..."
    $DC exec -T backend alembic -c alembic/alembic.ini upgrade head
    green "Migrations complete."
    echo ""

    # Create admin user
    bold "Creating admin account..."
    $DC exec -T backend python -m app.cli.create_admin \
        --email "$admin_email" \
        --password "$admin_password" \
        --org-name "$org_name" \
        --org-slug "$org_slug"
    green "Admin account created."
    echo ""

    local access_url
    access_url=$(get_access_url)

    bold "=== Setup Complete ==="
    echo ""
    echo "Access bioAF at: $access_url"
    echo "Log in with: $admin_email"
    echo ""
    echo "Next steps:"
    echo "  - Open $access_url in your browser"
    echo "  - Log in with your admin credentials"
    echo "  - Configure SMTP, compute stack, and invite your team from Settings"
    echo ""
    echo "Management commands:"
    echo "  ./bioaf status     Show service status"
    echo "  ./bioaf logs       Tail logs"
    echo "  ./bioaf stop       Stop all services"
    echo "  ./bioaf help       Show all commands"
}

cmd_start() {
    bold "=== Starting Services ==="
    $DC up -d
    green "All services started."
    cmd_status
}

cmd_stop() {
    bold "=== Stopping Services ==="
    $DC stop
    green "All services stopped."
}

cmd_restart() {
    bold "=== Restarting Services ==="
    $DC restart
    green "All services restarted."
}

cmd_status() {
    bold "=== Service Status ==="
    echo ""
    $DC ps --format "table {{.Service}}\t{{.Status}}\t{{.Ports}}"
    echo ""
}

cmd_logs() {
    local service="${1:-}"
    if [ -n "$service" ]; then
        $DC logs -f --tail=100 "$service"
    else
        $DC logs -f --tail=50
    fi
}

cmd_migrate() {
    bold "=== Running Database Migrations ==="
    wait_for_db
    $DC exec -T backend alembic -c alembic/alembic.ini upgrade head
    green "Migrations complete."
}

cmd_backup() {
    bold "=== Database Backup ==="
    local timestamp
    timestamp=$(date +%Y%m%d_%H%M%S)
    local backup_file="$SCRIPT_DIR/backups/bioaf_${timestamp}.sql.gz"
    mkdir -p "$SCRIPT_DIR/backups"

    $DC exec -T db pg_dump -U bioaf bioaf | gzip > "$backup_file"
    green "Backup saved to: $backup_file"
}

cmd_update() {
    bold "=== Updating bioAF ==="

    echo "Pulling latest code..."
    git -C "$SCRIPT_DIR" pull

    echo "Rebuilding containers..."
    $DC up -d --build

    wait_for_db

    echo "Running migrations..."
    $DC exec -T backend alembic -c alembic/alembic.ini upgrade head

    green "Update complete."
}

cmd_build() {
    local service="${1:-}"
    if [ -n "$service" ]; then
        bold "=== Building $service ==="
        $DC build "$service"
        green "$service built."
    else
        bold "=== Building All Services ==="
        $DC build
        green "All services built."
    fi
}

cmd_shell() {
    local service="${1:-backend}"
    bold "Opening shell in $service..."
    $DC exec "$service" sh
}

cmd_dbshell() {
    bold "Opening database shell..."
    $DC exec db psql -U bioaf bioaf
}

cmd_seed() {
    local script="${1:-}"
    if [ -z "$script" ]; then
        red "Usage: ./bioaf seed <script.py>"
        echo ""
        echo "Available seed scripts:"
        # List .py files in scripts/ that contain 'seed' or 'generate' in the name
        find "$SCRIPT_DIR/scripts" -maxdepth 1 -name "*.py" -type f 2>/dev/null | sort | while read -r f; do
            echo "  $(basename "$f")"
        done
        exit 1
    fi

    # Resolve the script path relative to scripts/ if not absolute
    local script_path
    if [ -f "$SCRIPT_DIR/scripts/$script" ]; then
        script_path="scripts/$script"
    elif [ -f "$script" ]; then
        script_path="$script"
    else
        red "Script not found: $script"
        red "Looked in: $SCRIPT_DIR/scripts/$script"
        exit 1
    fi

    bold "=== Running seed script: $script_path ==="
    $DC exec -T backend python "$script_path"
    green "Seed script complete."
}

cmd_create_admin() {
    bold "=== Create Admin Account ==="
    echo ""

    # Prompt for org name
    read -rp "Organization name: " org_name
    if [ -z "$org_name" ]; then
        red "Organization name cannot be empty."
        exit 1
    fi

    org_slug=$(slugify "$org_name")
    echo "  Org slug: $org_slug"
    echo ""

    # Prompt for admin email
    read -rp "Admin email: " admin_email
    if [ -z "$admin_email" ]; then
        red "Admin email cannot be empty."
        exit 1
    fi

    # Prompt for admin password (hidden)
    while true; do
        read -rsp "Admin password: " admin_password
        echo ""
        read -rsp "Confirm password: " admin_password_confirm
        echo ""
        if [ "$admin_password" = "$admin_password_confirm" ]; then
            break
        fi
        red "Passwords do not match. Try again."
    done
    echo ""

    bold "Creating admin account..."
    $DC exec -T backend python -m app.cli.create_admin \
        --email "$admin_email" \
        --password "$admin_password" \
        --org-name "$org_name" \
        --org-slug "$org_slug"
    green "Admin account created."
    echo ""
    echo "Log in at $(get_access_url) with: $admin_email"
}

cmd_reset_db() {
    bold "=== Database Reset ==="
    red "WARNING: This will destroy ALL data in the database."
    read -rp "Type 'yes' to confirm: " confirm
    if [ "$confirm" != "yes" ]; then
        echo "Aborted."
        exit 0
    fi

    echo "Stopping backend..."
    $DC stop backend

    echo "Dropping and recreating database..."
    $DC exec -T db dropdb -U bioaf --if-exists bioaf
    $DC exec -T db createdb -U bioaf bioaf

    echo "Starting backend..."
    $DC start backend

    wait_for_db

    echo "Running migrations..."
    $DC exec -T backend alembic -c alembic/alembic.ini upgrade head

    green "Database reset complete. Run './bioaf setup' to create a new admin account."
}

cmd_help() {
    bold "bioAF Management"
    echo ""
    echo "Usage: ./bioaf <command> [args]"
    echo ""
    bold "First-Run:"
    echo "  setup               Interactive setup wizard (generates .env, starts services, creates admin)"
    echo "  create-admin        Create an admin user account (services must be running)"
    echo ""
    bold "Service Management:"
    echo "  start               Start all services"
    echo "  stop                Stop all services"
    echo "  restart             Restart all services"
    echo "  status              Show status of all services"
    echo "  logs [service]      Tail logs (all services, or just one)"
    echo "  build [service]     Build (or rebuild) container images"
    echo ""
    bold "Database:"
    echo "  migrate             Run alembic database migrations"
    echo "  seed <script.py>    Run a seed/data script in the backend container"
    echo "  backup              Create a database backup"
    echo "  reset-db            Destroy and recreate the database (with confirmation)"
    echo ""
    bold "Debugging:"
    echo "  shell [service]     Open a shell in a container (default: backend)"
    echo "  dbshell             Open a psql session to the database"
    echo ""
    bold "Maintenance:"
    echo "  update              Pull latest code, rebuild containers, and run migrations"
    echo "  help                Show this help message"
    echo ""
    bold "Examples:"
    echo "  ./bioaf setup               # First-time setup"
    echo "  ./bioaf build               # Build all container images"
    echo "  ./bioaf start               # Start services"
    echo "  ./bioaf logs backend        # Tail backend logs"
    echo "  ./bioaf migrate             # Run pending migrations"
    echo "  ./bioaf seed seed_poc_data.py  # Seed demo data"
    echo "  ./bioaf shell backend       # Open shell in backend"
    echo "  ./bioaf dbshell             # Open psql session"
    echo "  ./bioaf backup              # Create database backup"
    echo ""
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------
command="${1:-help}"
shift || true

case "$command" in
    setup)        cmd_setup ;;
    create-admin) cmd_create_admin ;;
    start)        cmd_start ;;
    stop)     cmd_stop ;;
    restart)  cmd_restart ;;
    status)   cmd_status ;;
    logs)     cmd_logs "$@" ;;
    build)    cmd_build "$@" ;;
    migrate)  cmd_migrate ;;
    seed)     cmd_seed "$@" ;;
    backup)   cmd_backup ;;
    shell)    cmd_shell "$@" ;;
    dbshell)  cmd_dbshell ;;
    update)   cmd_update ;;
    reset-db) cmd_reset_db ;;
    help|-h|--help) cmd_help ;;
    *)
        red "Unknown command: $command"
        echo ""
        cmd_help
        exit 1
        ;;
esac
